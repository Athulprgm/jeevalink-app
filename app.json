{
  "expo": {
    "name": "JeevaLink",
    "slug": "jeevalink-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "scheme": "jeevalinkapp",
    "userInterfaceStyle": "automatic",

    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#A41118"
    },

    "ios": {
      "icon": "./assets/logo.png"
    },

    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#A41118"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.athulkrishnak.jeevalinkapp"
    },

    "web": {
      "output": "static",
      "favicon": "./assets/logo.png"
    },

    "plugins": ["expo-router", "expo-video"],

    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },

    "extra": {
      "router": {},
      "eas": {
        "projectId": "4043905c-09f5-4046-b1f3-ae6ec160f3bf"
      }
    }
  }
}
